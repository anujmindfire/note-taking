# Copy this file to .env.test and fill in the values before running E2E tests.
# .env.test is gitignored — never commit it.

# Dedicated E2E test database — must differ from DATABASE_URL to avoid wiping dev data.
# The global setup resets this database before every full suite run.
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/Note_e2e?schema=public

# Frontend base URL. Defaults to http://localhost:5173 if not set.
# Override in CI to point at a staging deployment.
BASE_URL=http://localhost:5173

# E2E seed user credentials. Used by global.setup.ts to register/login the test user.
E2E_USER_EMAIL=e2e@test.com
E2E_USER_PASSWORD=your-e2e-test-password
